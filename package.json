{
  "name": "campaignops",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @campaignops/web --filter @campaignops/api dev",
    "dev:web": "pnpm --filter @campaignops/web dev",
    "dev:api": "pnpm --filter @campaignops/api dev",
    "build": "pnpm prisma:generate && pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prisma": "^6.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
