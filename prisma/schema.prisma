generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganizationRole {
  ADMIN
  MANAGER
  MEMBER
}

enum EventCategory {
  GOVERNMENT_CSR
  PRIME_CIRCLE
  HOLY_SIN_CAFE
  PRIVATE_CLIENT
}

enum EventScaleTier {
  MICRO
  SMALL
  MEDIUM
  LARGE
  MASS
}

enum EventStatus {
  DRAFT
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
  BLOCKED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ContactCategory {
  SPONSOR
  GOVERNMENT_OFFICER
  COLLEGE
  VENDOR
  VOLUNTEER
  MEDIA
  INFLUENCER
  GUEST
  CLIENT
  SPEAKER
  PERFORMER
  PARTNER
  SUPPORTER
}

enum ContactStatus {
  NEW
  CONTACTED
  INTERESTED
  FOLLOW_UP
  CONVERTED
  NOT_INTERESTED
  CLOSED
}

enum VendorCategory {
  VENUE
  CATERING
  SOUND
  LIGHT
  STAGE
  PRINTING
  DECOR
  PHOTOGRAPHY
  VIDEOGRAPHY
  TRANSPORT
  SECURITY
  REGISTRATION
  ARTISTS
  ANCHORS
  FABRICATION
}

enum PaymentStatus {
  NOT_STARTED
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

enum BudgetCategory {
  VENUE
  FOOD
  PRINTING
  BRANDING
  STAGE
  SOUND
  LIGHTING
  TRAVEL
  PHOTOGRAPHY
  VIDEOGRAPHY
  ADS
  TEAM
  GUEST_HOSPITALITY
  VENDOR_PAYMENTS
  MISCELLANEOUS
}

enum ContentPlatform {
  INSTAGRAM
  LINKEDIN
  FACEBOOK
  X_TWITTER
  WHATSAPP
  YOUTUBE
  PRESS
  OFFLINE_POSTERS
  STANDEE_BANNER
}

enum ContentApprovalStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  PUBLISHED
}

enum FileCategory {
  PROPOSAL
  BUDGET
  POSTER
  CREATIVE
  AGREEMENT
  PERMISSION
  QUOTATION
  REPORT
  PHOTO
  VIDEO
  PR_DOCUMENT
  TEMPLATE
}

enum AIWorkflowType {
  EVENT_PLAN
  STRATEGY
  BUDGET
  TASK_BREAKDOWN
  OUTREACH
  CONTENT_CALENDAR
  RISK_CHECKLIST
  PROPOSAL
  POST_EVENT_REPORT
}

enum AIWorkflowStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  ACCEPTED
}

enum AIOutputType {
  EVENT_PLAN
  STRATEGY
  BUDGET
  TASKS
  OUTREACH
  CONTENT_CALENDAR
  RISK_CHECKLIST
  REPORT
}

enum OutreachRecipientType {
  SPONSOR
  COLLEGE
  GOVERNMENT_DEPARTMENT
  PSU
  VOLUNTEER
  SPEAKER
  INFLUENCER
  MEDIA
  VENDOR
  CLIENT
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  passwordHash        String
  refreshTokenHash    String?
  refreshTokenExpiresAt DateTime?
  name                String
  phone               String?
  designation         String?
  avatarUrl           String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  organizationMembers OrganizationMember[]
  createdEvents       Event[]              @relation("EventCreatedBy")
  assignedTasks       Task[]               @relation("TaskAssignee")
  createdTasks        Task[]               @relation("TaskCreatedBy")
  uploadedFiles       FileAsset[]          @relation("FileUploadedBy")
  aiWorkflowRuns      AIWorkflowRun[]      @relation("AIWorkflowRunCreatedBy")
  aiOutputs           AIOutput[]           @relation("AIOutputCreatedBy")
  activityLogs        ActivityLog[]
  contentItems        ContentItem[]        @relation("ContentOwner")
  outreachTemplates   OutreachTemplate[]   @relation("OutreachTemplateCreatedBy")
  sentInvitations      OrganizationInvitation[] @relation("OrganizationInvitationInvitedBy")
  acceptedInvitations  OrganizationInvitation[] @relation("OrganizationInvitationAcceptedBy")
  passwordResetTokens  PasswordResetToken[]
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Organization {
  id                 String               @id @default(cuid())
  name               String
  profileImageUrl    String?
  defaultCurrency    String               @default("INR")
  timezone           String               @default("Asia/Kolkata")
  brandKitJson       Json?
  settingsJson       Json?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  members            OrganizationMember[]
  events             Event[]
  contacts           Contact[]
  vendors            Vendor[]
  files              FileAsset[]
  outreachTemplates  OutreachTemplate[]
  aiWorkflowRuns     AIWorkflowRun[]
  activityLogs       ActivityLog[]
  playbookEntries    PlaybookEntry[]
  knowledgeDocuments KnowledgeDocument[]
  promptTemplates    PromptTemplate[]
  invitations        OrganizationInvitation[]
}

model OrganizationMember {
  id             String           @id @default(cuid())
  organizationId String
  userId         String
  role           OrganizationRole @default(MEMBER)
  invitedAt      DateTime?
  joinedAt       DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

model OrganizationInvitation {
  id             String           @id @default(cuid())
  organizationId String
  invitedById    String
  acceptedById   String?
  email          String
  role           OrganizationRole @default(MEMBER)
  tokenHash      String           @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  revokedAt      DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy      User             @relation("OrganizationInvitationInvitedBy", fields: [invitedById], references: [id])
  acceptedBy     User?            @relation("OrganizationInvitationAcceptedBy", fields: [acceptedById], references: [id])

  @@index([organizationId, email])
  @@index([email])
  @@index([invitedById])
  @@index([acceptedById])
}

model Event {
  id                    String           @id @default(cuid())
  organizationId        String
  createdById           String
  title                 String
  objective             String?
  category              EventCategory
  subtype               String
  scaleTier             EventScaleTier
  city                  String?
  venue                 String?
  expectedPax           Int?
  estimatedBudgetAmount Decimal?         @db.Decimal(12, 2)
  actualBudgetAmount    Decimal?         @db.Decimal(12, 2)
  startsAt              DateTime?
  endsAt                DateTime?
  departmentOrClient    String?
  stakeholdersJson      Json?
  brandContext          String?
  status                EventStatus      @default(DRAFT)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  organization          Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy             User             @relation("EventCreatedBy", fields: [createdById], references: [id])
  tasks                 Task[]
  budgetItems           BudgetItem[]
  contentItems          ContentItem[]
  fileAssets            FileAsset[]
  outreachTemplates     OutreachTemplate[]
  aiWorkflowRuns        AIWorkflowRun[]
  aiOutputs             AIOutput[]
  activityLogs          ActivityLog[]
  eventContacts         EventContact[]
  eventVendors          EventVendor[]
  playbookEntries       PlaybookEntry[]

  @@index([organizationId, status])
  @@index([category, scaleTier])
}

model Task {
  id             String       @id @default(cuid())
  eventId        String
  createdById    String
  assigneeId     String?
  title          String
  description    String?
  status         TaskStatus   @default(TODO)
  priority       TaskPriority @default(MEDIUM)
  dueAt          DateTime?
  notes          String?
  checklistJson  Json?
  attachmentsJson Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  event          Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdBy      User         @relation("TaskCreatedBy", fields: [createdById], references: [id])
  assignee       User?        @relation("TaskAssignee", fields: [assigneeId], references: [id])

  @@index([eventId, status])
  @@index([assigneeId, status])
}

model Contact {
  id             String          @id @default(cuid())
  organizationId String
  name           String
  phone          String?
  email          String?
  organizationName String?
  designation    String?
  category       ContactCategory
  source         String?
  status         ContactStatus   @default(NEW)
  notes          String?
  followUpAt     DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  eventContacts  EventContact[]

  @@index([organizationId, category])
  @@index([organizationId, status])
}

model EventContact {
  id        String   @id @default(cuid())
  eventId   String
  contactId String
  notes     String?
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([eventId, contactId])
  @@index([contactId])
}

model Vendor {
  id               String        @id @default(cuid())
  organizationId   String
  name             String
  category         VendorCategory
  contactName      String?
  phone            String?
  email            String?
  city             String?
  serviceType      String?
  rateCardJson     Json?
  pastEventsServed Int?
  rating           Int?
  notes            String?
  paymentStatus    PaymentStatus @default(NOT_STARTED)
  quotationFileId  String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  organization     Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  eventVendors     EventVendor[]
  budgetItems      BudgetItem[]

  @@index([organizationId, category])
  @@index([organizationId, city])
}

model EventVendor {
  id                String   @id @default(cuid())
  eventId           String
  vendorId          String
  performanceNotes  String?
  createdAt         DateTime @default(now())
  event             Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  vendor            Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([eventId, vendorId])
  @@index([vendorId])
}

model BudgetItem {
  id              String        @id @default(cuid())
  eventId         String
  vendorId        String?
  category        BudgetCategory
  title           String
  estimatedAmount Decimal       @default(0) @db.Decimal(12, 2)
  actualAmount    Decimal       @default(0) @db.Decimal(12, 2)
  paymentStatus   PaymentStatus @default(NOT_STARTED)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  event           Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  vendor          Vendor?       @relation(fields: [vendorId], references: [id])

  @@index([eventId, category])
  @@index([vendorId])
}

model ContentItem {
  id             String                @id @default(cuid())
  eventId        String
  ownerId        String?
  platform       ContentPlatform
  title          String
  caption        String?
  scheduledFor   DateTime?
  approvalStatus ContentApprovalStatus @default(DRAFT)
  assetFileId    String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  event          Event                 @relation(fields: [eventId], references: [id], onDelete: Cascade)
  owner          User?                 @relation("ContentOwner", fields: [ownerId], references: [id])
  assetFile      FileAsset?            @relation(fields: [assetFileId], references: [id])

  @@index([eventId, platform])
  @@index([ownerId])
}

model FileAsset {
  id             String        @id @default(cuid())
  organizationId String
  eventId        String?
  uploadedById   String
  category       FileCategory
  fileName       String
  fileUrl        String
  mimeType       String?
  sizeBytes      Int?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  event          Event?        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  uploadedBy     User          @relation("FileUploadedBy", fields: [uploadedById], references: [id])
  contentItems   ContentItem[]

  @@index([organizationId, category])
  @@index([eventId])
}

model OutreachTemplate {
  id             String                @id @default(cuid())
  organizationId String
  eventId        String?
  createdById    String
  recipientType  OutreachRecipientType
  title          String
  channel        String
  body           String
  version        Int                   @default(1)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  event          Event?                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdBy      User                  @relation("OutreachTemplateCreatedBy", fields: [createdById], references: [id])

  @@index([organizationId, recipientType])
  @@index([eventId])
}

model AIWorkflowRun {
  id                   String           @id @default(cuid())
  organizationId       String
  eventId              String?
  workflowType         AIWorkflowType
  inputJson            Json
  retrievedContextJson Json?
  outputJson           Json?
  status               AIWorkflowStatus @default(PENDING)
  modelUsed            String?
  createdById          String
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  organization         Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  event                Event?           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdBy            User             @relation("AIWorkflowRunCreatedBy", fields: [createdById], references: [id])

  @@index([organizationId, workflowType])
  @@index([eventId])
}

model AIOutput {
  id           String       @id @default(cuid())
  eventId      String
  outputType   AIOutputType
  title        String
  responseJson Json
  isAccepted   Boolean      @default(false)
  createdById  String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  event        Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("AIOutputCreatedBy", fields: [createdById], references: [id])

  @@index([eventId, outputType])
}

model ActivityLog {
  id             String       @id @default(cuid())
  organizationId String
  eventId        String?
  userId         String?
  action         String
  entityType     String
  entityId       String?
  metadataJson   Json?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  event          Event?       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id])

  @@index([organizationId, createdAt])
  @@index([eventId])
}

model PromptTemplate {
  id                 String         @id @default(cuid())
  organizationId     String
  workflowType       AIWorkflowType
  name               String
  systemPrompt       String
  userPromptTemplate String
  outputSchema       Json
  version            Int            @default(1)
  isActive           Boolean        @default(true)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  organization       Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, workflowType, isActive])
}

model PlaybookEntry {
  id              String       @id @default(cuid())
  organizationId  String
  eventId         String?
  eventType       EventCategory
  scale           EventScaleTier
  city            String?
  budgetRange     String?
  learningsJson   Json
  vendorNotesJson Json?
  riskNotesJson   Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  event           Event?       @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([organizationId, eventType, scale])
}

model KnowledgeDocument {
  id              String           @id @default(cuid())
  organizationId  String
  title           String
  category        String
  fileUrl         String?
  extractedText   String?
  embeddingStatus String           @default("pending")
  uploadedById    String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  chunks          KnowledgeChunk[]

  @@index([organizationId, category])
}

model KnowledgeChunk {
  id           String            @id @default(cuid())
  documentId   String
  chunkText    String
  metadataJson Json?
  createdAt    DateTime          @default(now())
  document     KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}
